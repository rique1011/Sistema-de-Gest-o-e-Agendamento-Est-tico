@startuml C4_Container_BioSchedule
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Diagrama de Contêineres (Nível 2 ) - BioSchedule

Person(recepcionista, "Recepcionista / Admin", "Gerencia agenda, pacientes, serviços e configurações")
Person(biomedico, "Biomédico / Profissional", "Consulta agenda, prontuários e dashboard")

System_Boundary(bioschedule, "BioSchedule") {

    Container(frontend, "Frontend Web (Branch: frontend)", "React / Vite / Tailwind", "Interface SPA responsiva para gestão de agendamentos, pacientes e catálogo de serviços. Consome a API REST via Axios.")

    Container(backend, "API Backend (Branch: backend)", "Node.js / NestJS", "Provê endpoints RESTful para lógica de negócio: CRUD de pacientes, serviços, agendamentos, bloqueios e configurações de expediente.")

    ContainerDb(database, "Banco de Dados", "PostgreSQL", "Armazena de forma relacional: usuários, pacientes, serviços, agendamentos, bloqueios e configurações de agenda via Prisma ORM.")

}

System_Ext(email_system, "Sistema de E-mail (SMTP)", "Serviço externo de notificações para lembretes de agendamento.")

Rel(recepcionista, frontend, "Acessa via", "HTTPS / Browser")
Rel(biomedico, frontend, "Acessa via", "HTTPS / Browser")

Rel(frontend, backend, "Faz chamadas REST para", "JSON / HTTPS")

Rel(backend, database, "Lê e escreve dados usando", "Prisma ORM / TCP")

Rel(backend, email_system, "Envia notificações via", "SMTP")

@enduml
