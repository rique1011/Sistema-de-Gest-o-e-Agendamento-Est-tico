generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // A linha 'url = env(...)' foi removida daqui!
}

model Paciente {
  id           String         @id @default(uuid())
  nome         String
  cpf          String         @unique
  telefone     String
  email        String?
  agendamentos Agendamento[]
  createdAt    DateTime       @default(now())
}

model Servico {
  id               String         @id @default(uuid())
  nome             String
  duracao_minutos  Int
  valor            Decimal        @db.Decimal(10, 2)
  agendamentos     Agendamento[]
}

model Agendamento {
  id          String   @id @default(uuid())
  data_inicio DateTime
  data_fim    DateTime
  status      Status   @default(AGENDADO)
  
  paciente    Paciente @relation(fields: [pacienteId], references: [id])
  pacienteId  String
  
  servico     Servico  @relation(fields: [servicoId], references: [id])
  servicoId   String

  createdAt   DateTime @default(now())
}

enum Status {
  AGENDADO
  EM_ATENDIMENTO
  CONCLUIDO
  FALTOU
  CANCELADO
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String   // Aqui vamos guardar a senha criptografada (nunca em texto puro!)
  criado_em DateTime @default(now())

  @@map("usuarios")
}